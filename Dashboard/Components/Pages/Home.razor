@page "/" 
@inject Dashboard.Services.AlertService AlertService
@inject IJSRuntime JS

<h1>🛡️ SOC Dashboard</h1>

@if (alerts == null)
{
    <p>Loading alerts...</p>
}
else if (!alerts.Any())
{
    <p>No alerts found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Time</th>
                <th>Type</th>
                <th>Severity</th>
                <th>Protocol</th>
                <th>Service</th>
                <th>Src Bytes</th>
                <th>Dst Bytes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var alert in alerts)
            {
                <tr @key="alert.Timestamp">
                    <td>@alert.Timestamp</td>
                    <td>@alert.Alert_Type</td>
                    <td>@alert.Severity</td>
                    <td>@alert.ProtocolType</td>
                    <td>@alert.Service</td>
                    <td>@alert.Src_Bytes</td>
                    <td>@alert.Dst_Bytes</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Dashboard.Models.Alert> alerts = new List<Dashboard.Models.Alert>();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Load initial alerts via HTTP
            alerts = await AlertService.GetAlertsAsync();

            // Connect to JS WebSocket for live updates
            await JS.InvokeVoidAsync("alertsocket.connect",
                DotNetObjectReference.Create(this));

            StateHasChanged();
        }
    }

    [JSInvokable]
    public void ReceiveAlert(Dashboard.Models.Alert alert)
    {
        alerts.Insert(0, alert); // newest on top
        StateHasChanged();
    }

    public void Dispose()
    {
        // Clean up if needed
    }
}
